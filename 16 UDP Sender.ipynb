    "s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)\n",
    "num = 0\n",
    "while True:\n",
    "    print(f\"Sending... {num}\")\n",
    "    s.sendto(str(num).encode('utf-8'), ('localhost',2345))\n",
    "    num += 1\n",
    "    time.sleep(1)"
